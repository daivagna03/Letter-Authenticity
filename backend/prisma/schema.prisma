// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id
  name          String
  role          Role     @default(PRIMARY)
  email         String   @unique
  employeeId    String?  @unique
  passwordHash  String
  
  // Configuration fields
  designation   String?
  department    String?
  organization  String?
  defaultAddress String?
  
  // Operator relations
  parentUserId  String?
  parentUser    User?    @relation("UserToOperator", fields: [parentUserId], references: [id])
  operators     User[]   @relation("UserToOperator")

  letters       Letter[]  @relation("LetterSender")
  draftedLetters Letter[]  @relation("LetterDrafter")
  createdAt     DateTime @default(now())
}

enum Role {
  PRIMARY
  OPERATOR
  ADMIN
}

model Letter {
  id              String    @id
  senderId        String
  sender          User      @relation("LetterSender", fields: [senderId], references: [id])
  draftedById     String?
  draftedBy       User?     @relation("LetterDrafter", fields: [draftedById], references: [id])
  refNo           String    @unique
  date            DateTime
  recipientName   String
  recipientAddress String
  subject         String
  body            String    @db.Text
  signatureBlock  String
  copyTo          String?   @db.Text
  hash            String    
  qrToken         String    @unique 
  pdfData         Bytes?
  scanLogs        ScanLog[]
  createdAt       DateTime  @default(now())
}

model ScanLog {
  id          String   @id
  letterId    String
  letter      Letter   @relation(fields: [letterId], references: [id], onDelete: Cascade)
  scannedAt   DateTime @default(now())
  ipAddress   String?
  location    String?  
  deviceInfo  String?  
}
