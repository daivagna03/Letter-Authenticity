// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id
  name          String
  role          Role     @default(MAIN_USER)
  email         String   @unique
  employeeId    String?  @unique
  passwordHash  String
  isActive      Boolean  @default(true)

  // Mode: determines which templates are available and how letters are formatted
  mode          Mode     @default(ORGANIZATION)

  // Organization mode fields
  designation   String?
  department    String?
  organization  String?
  defaultAddress String?

  // Political mode fields (MLA / MP)
  constituency  String?
  state         String?
  houseType     String?   // e.g. "Lok Sabha", "Rajya Sabha", "State Assembly"

  // Signature & Seal (for PDF letterhead)
  signatureUrl  String?
  sealUrl       String?

  // Operator relations
  parentUserId  String?
  parentUser    User?    @relation("UserToOperator", fields: [parentUserId], references: [id])
  operators     User[]   @relation("UserToOperator")

  // Operator-specific display label
  operatorRole  String?   // e.g. "Data Entry Operator", "Office Clerk"

  letters        Letter[]  @relation("LetterSender")
  draftedLetters Letter[]  @relation("LetterDrafter")
  createdAt      DateTime  @default(now())
}

enum Role {
  MAIN_USER
  OPERATOR
  ADMIN
}

enum Mode {
  ORGANIZATION
  POLITICAL
}

model Template {
  id          String   @id
  name        String
  slug        String   @unique   // e.g. "general", "state-central", "district-order", "mplad"
  mode        Mode?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  letters     Letter[]
}

model Letter {
  id              String    @id
  senderId        String
  sender          User      @relation("LetterSender", fields: [senderId], references: [id])
  draftedById     String?
  draftedBy       User?     @relation("LetterDrafter", fields: [draftedById], references: [id])

  // Template used for this letter
  templateId      String?
  template        Template? @relation(fields: [templateId], references: [id])

  refNo           String    @unique
  date            DateTime
  recipientName   String
  recipientDesignation String?   // Separate designation field
  recipientAddress String
  recipientAddressDetail String? @db.Text  // Separate address detail field
  subject         String
  body            String    @db.Text
  signatureBlock  String
  copyTo          String?   @db.Text

  // MPLAD-specific: JSON array of table rows [{priorityNo, workDescription, cost}]
  mplaadTableData String?   @db.Text

  // District Order specific
  memoNo          String?
  orderCopyList   String?   @db.Text   // JSON array of numbered copy recipients
  districtOrgName String?              // Per-letter org name override for header
  districtDeptName String?             // Per-letter dept name override for header

  hash            String
  qrToken         String    @unique
  pdfData         Bytes?

  // Audit trail
  createdByType    String?   // "main_user" | "operator"
  creatorIpAddress String?
  creatorLocation  String?

  scanLogs        ScanLog[]
  createdAt       DateTime  @default(now())
}

model ScanLog {
  id          String   @id
  letterId    String
  letter      Letter   @relation(fields: [letterId], references: [id], onDelete: Cascade)
  scannedAt   DateTime @default(now())
  ipAddress   String?
  location    String?
  deviceInfo  String?
}
